# ── Core ───────────────────────────────────────────────
  ASSISTANT_NAME=luis
  LOG_LEVEL=info
  # NODE_ENV=production

  # ── Local LLM (endpoint OpenAI-compatible) ─────────────
  LLM_PROVIDER=local
  LOCAL_LLM_BASE_URL=http://<llm-host>:11434     # Ollama; LiteLLM: http://<host>:8080/v1
  LOCAL_LLM_MODEL=
  LOCAL_LLM_API_KEY=                              # solo si el endpoint lo exige (LiteLLM)
  LOCAL_LLM_TIMEOUT_MS=120000
  ALLOW_CLOUD_LLM=false

  # ── Web UI (solo LAN) ──────────────────────────────────
  WEB_ENABLED=true
  WEB_PUBLISHED_PORT=3030                          # puerto host -> :3000 del contenedor

  # ── Web tools ──────────────────────────────────────────
  WEB_SEARCH_BASE_URL=                             # SearXNG, ej: http://<host>:8888
  URL_FETCH_ALLOW_PRIVATE=false
  URL_FETCH_ALLOWLIST=                             # CSV de hosts/IPs privados permitidos

  # ── Downloads ──────────────────────────────────────────
  DOWNLOADS_PATH=/tmp/downloads
  DOWNLOAD_RULES_PATH=./config/download-rules.json
  ENABLE_LLM_FILE_CLASSIFICATION=false

  # ── Telegram ───────────────────────────────────────────
  TELEGRAM_BOT_TOKEN=                              # @BotFather
  TELEGRAM_ALLOWED_CHAT_IDS=                       # CSV de chat IDs (@userinfobot)
  TELEGRAM_NOTIFY_CHAT_ID=                         # alertas; vacío = primer allowed

  # ── Home Assistant (opcional) ──────────────────────────
  HA_BASE_URL=                                     # ej: http://<ha-host>:8123
  HA_TOKEN=                                         # token de larga duración de HA
  HA_LANGUAGE=es
  HA_AGENT_ID=                                      # ej: conversation.home_assistant

  # ── Cluster watcher (opcional) ─────────────────────────
  CLUSTER_ENABLED=false                             # true para activarlo
  CLUSTER_N2_IP=                                    # requeridas si CLUSTER_ENABLED=true
  CLUSTER_N3_IP=
  CLUSTER_N4_IP=

  # ── Prometheus (consultas "¿algo caído?" bajo demanda) ─
  PROMETHEUS_ENABLED=false                          # true para activarlo
  PROMETHEUS_BASE_URL=                              # requerida si enabled; ej: http://<host>:9090
  PROMETHEUS_TIMEOUT_MS=8000

  # ── Docker ─────────────────────────────────────────────
  CONTAINER_NAME=luis

  # ── Watchtower → Telegram (opcional) ───────────────────
  WATCHTOWER_WEBHOOK_TOKEN=                         # token compartido para POST /api/hooks/watchtower (ver DEPLOYMENT.md §9)
